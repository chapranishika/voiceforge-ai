# VoiceForge AI — Frontend Environment Variables
# Copy this file to .env and update if needed

# Backend API URL (leave as /api for same-origin proxy, or set full URL for separate deployments)
VITE_API_URL=/api

# For separate frontend/backend deployments (e.g., Vercel + Railway):
# VITE_API_URL=https://your-backend.railway.app/api
